# Supabase — öffentliche Werte (dürfen ins Client-Bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Supabase — service-role: umgeht RLS, AUSSCHLIESSLICH serverseitig verwenden.
# Kein NEXT_PUBLIC_-Prefix, damit der Wert nie im Client landet.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — nur serverseitig (KI-Generierung der Bautagesberichte)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: überschreibt das Standardmodell der KI-Generierung.
# ANTHROPIC_MODEL=claude-sonnet-5
